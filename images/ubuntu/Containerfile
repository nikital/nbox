FROM docker.io/library/ubuntu:24.04
ARG USER
ARG UID
ARG HOME

# Disable apt sandbox, not sure why it doesn't work but it's not important.
RUN echo 'APT::Sandbox::User "root";' > /etc/apt/apt.conf.d/99no-sandbox && \
    apt-get update && \
    apt-get install -y sudo && \
    rm -rf /var/lib/apt/lists/*

# Ubuntu 24.04 ships a default 'ubuntu' user at UID 1000
RUN userdel -r $(getent passwd $UID | cut -d: -f1) 2>/dev/null; \
    useradd -u $UID -d $HOME -m $USER && \
    echo "$USER ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/$USER && \
    chmod 440 /etc/sudoers.d/$USER && \
    echo "$USER:2000:63000" > /etc/subuid && \
    echo "$USER:2000:63000" > /etc/subgid
